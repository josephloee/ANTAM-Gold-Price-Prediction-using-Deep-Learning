\n","    # )\n","\n","    model_checkpoint = ModelCheckpoint(\n","        filepath=model_path,\n","        monitor='val_loss',\n","        save_best_only=True,\n","        verbose=1\n","    )\n","\n","    reduce_lr = ReduceLROnPlateau(\n","        monitor='val_loss',\n","        factor=0.5,\n","        patience=5,\n","        min_lr=1e-7,\n","        verbose=1\n","    )\n","\n","    callbacks = [model_checkpoint, reduce_lr] #tambah early_stopping jika perlu\n","\n","    # Training\n","    print(f\"\\n🚀 Training model split {split_labels[idx]}...\")\n","    print(f\"⏰ Ini mungkin memakan waktu beberapa menit...\")\n","\n","    start_time = datetime.now()\n","\n","    history = model.fit(\n","        X_train, y_train,\n","        epochs=50,\n","        batch_size=32,\n","        validation_split=0.2,\n","        callbacks=callbacks,\n","        verbose=1\n","    )\n","\n","    end_time = datetime.now()\n","    training_duration = (end_time - start_time).total_seconds()\n","\n","    print(f\"\\n✓ Training selesai dalam {training_duration:.2f} detik\")\n","    print(f\"  Epochs trained: {len(history.history['loss'])}\")\n","    print(f\"  Final train loss: {history.history['loss'][-1]:.6f}\")\n","    print(f\"  Final val loss: {history.history['val_loss'][-1]:.6f}\")\n","\n","    # Prediksi\n","    print(f\"\\n🔮 Melakukan prediksi...\")\n","    y_pred = model.predict(X_test, verbose=0)\n","\n","    # Inverse transform\n","    y_test_actual = scaler.inverse_transform(y_test.reshape(-1, 1))\n","    y_pred_actual = scaler.inverse_transform(y_pred)\n","\n","    # Hitung metrik\n","    print(f\"\\n📊 Menghitung metrik evaluasi...\")\n","    metrics = calculate_metrics(y_test_actual, y_pred_actual)\n","\n","    print(f\"\\n{'='*60}\")\n","    print(f\"HASIL EVALUASI MODEL SPLIT {split_labels[idx]}\")\n","    print('='*60)\n","    print(f\"  RMSE: {metrics['RMSE']:.2f} IDR\")\n","    print(f\"  MAE:  {metrics['MAE']:.2f} IDR\")\n","    print(f\"  MAPE: {metrics['MAPE']:.2f}%\")